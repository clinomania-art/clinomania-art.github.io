---
---
[
  {% assign first = true %}
  {% for file in site.static_files %}
    {% if file.path contains '/assets/' %}
      {% assign ext = file.extname | downcase %}
      {% if ext == '.png' or ext == '.jpg' or ext == '.jpeg' or ext == '.svg' or ext == '.gif' or ext == '.webp' %}
        {% if first %}
          {% assign first = false %}
        {% else %}
          ,
        {% endif %}
        {
          "id": "{{ forloop.index }}",
          "title": "{{ file.basename }}",
          "filename": "{{ file.name }}",
          "path": "{{ file.path }}"
        }
      {% endif %}
    {% endif %}
  {% endfor %}
]
